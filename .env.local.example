# GitHub repo that stores content (see docs/GITHUB_RELEASE_ASSETS.md).
# Reads default to MilkdromedaStudios/DigitBox with no configuration; the
# token raises API rate limits and is required for publishing from the admin.
GITHUB_REPO_OWNER=MilkdromedaStudios
GITHUB_REPO_NAME=DigitBox
GITHUB_TOKEN=
# Release tag that holds the game HTML assets (default: game-assets)
GITHUB_ASSETS_TAG=game-assets

# Optional: public URL of the Cloudflare R2 bucket that holds game/post HTML
# files (see docs/CLOUDFLARE_R2_SETUP.md). Example: https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# ---- Digitbox AI ----------------------------------------------------------
# Set AI_API_KEY to switch Digitbox AI on. It speaks the OpenAI-compatible
# chat API, so any of these free providers work. Default is GitHub Models.
# See docs/DIGITBOX_AI_SETUP.md.
#
#   AI_PROVIDER=github       # https://github.com/marketplace/models  (key = GitHub PAT, "models: read")
#   AI_PROVIDER=groq         # https://console.groq.com  (free, fast)
#   AI_PROVIDER=gemini       # https://aistudio.google.com/apikey (free)
#   AI_PROVIDER=openrouter   # https://openrouter.ai  (free ":free" models)
#   AI_PROVIDER=huggingface  # https://huggingface.co/settings/tokens
#
# IMPORTANT: AI_API_KEY is read at RUNTIME by the deployed site, so it must be
# set in the hosting env (Cloudflare Pages → Settings → Environment variables,
# or Vercel). A GitHub *repository* secret is only visible to GitHub Actions,
# not to the live site, so it won't switch the AI on by itself.
AI_PROVIDER=github
AI_API_KEY=
# Optional overrides:
# AI_MODEL=openai/gpt-4o-mini
# AI_BASE_URL=https://models.github.ai/inference
